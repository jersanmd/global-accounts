# Supabase
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_key

# Supabase Service Role (Edge Functions only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Crypto (USDC on Ethereum, BSC, TRON, Klaytn)
VITE_PLATFORM_USDC_ADDRESS=0x_your_eth_usdc_address
VITE_PLATFORM_BSC_ADDRESS=0x_your_bsc_usdc_address
VITE_PLATFORM_TRON_ADDRESS=T_your_tron_address
VITE_PLATFORM_KLAYTN_ADDRESS=0x_your_klaytn_address
VITE_PLATFORM_SOL_ADDRESS=your_sol_address
VITE_PLATFORM_ICP_ADDRESS=your_icp_address
VITE_ETHERSCAN_API_KEY=your_etherscan_api_key
